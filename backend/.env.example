# Database
# The app reads the first of these that is set (in this order):
#   MONGO_URL, MONGODB_URI, MONGO_CONNECTION_STRING, MONGO_URI
# Zeabur's prebuilt MongoDB service injects MONGO_CONNECTION_STRING;
# Emergent-imported apps often use MONGO_URI. All are accepted.
MONGO_URL=mongodb://localhost:27017
# MONGODB_URI=mongodb://localhost:27017
# MONGO_CONNECTION_STRING=mongodb://localhost:27017
# MONGO_URI=mongodb://localhost:27017
DB_NAME=learnhub

# Security (generate: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-me-to-a-random-secret

# Environment: development | production
ENVIRONMENT=development
COOKIE_SECURE=false
# Cookie SameSite policy: lax | strict | none.
# Leave this UNSET to get a safe automatic default: 'lax' for local/insecure dev
# and 'none' for secure production (ENVIRONMENT=production + COOKIE_SECURE=true),
# so a cross-domain SPA can keep its auth cookie instead of looping back to login.
# Set 'lax' explicitly when the SPA and API share a site (same-origin /api proxy).
# 'none' requires HTTPS and forces COOKIE_SECURE=true.
# COOKIE_SAMESITE=lax
CORS_ORIGINS=http://localhost:3000

# Admin account (created on first startup if missing; password reset on every
# startup when it differs from the stored hash). Set this value to reset the
# admin password for login.
#
# IMPORTANT: the values below are placeholders for local dev only. On Zeabur
# (or any deployed environment) you MUST set ADMIN_EMAIL/ADMIN_PASSWORD as
# real Variables on the API service, then redeploy/restart it — seeding only
# runs at container startup. If ADMIN_PASSWORD is left unset, no admin
# account is created at all and every login attempt gets "Invalid
# credentials" with no other visible error. Logging in with the literal
# placeholder value below will NOT work unless you actually set the API
# service's ADMIN_PASSWORD variable to that same string.
ADMIN_EMAIL=admin@learnhub.com
ADMIN_PASSWORD=change-me-in-production

# Optional second admin (both must be set; created/reset on startup like above)
ADMIN2_EMAIL=admin2@learnhub.com
ADMIN2_PASSWORD=change-me-admin2

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
# Checkout currency (ISO 4217). Admin → Stripe Payments can override. e.g. hkd, usd
STRIPE_CURRENCY=hkd
REQUIRE_STRIPE_WEBHOOK_SECRET=false

# Deepseek AI (https://platform.deepseek.com)
DEEPSEEK_API_KEY=

# xAI (https://x.ai/api)
XAI_API_KEY=

# Encryption key for stored API keys (e.g. Fernet key or any string; used to derive Fernet key)
# Optional but recommended for production. If omitted, keys are stored in plaintext.
SETTINGS_ENCRYPTION_KEY=

# Brevo Email (https://app.brevo.com/settings/keys/api)
BREVO_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=LearnHub

# Frontend URL (for email links and CORS)
FRONTEND_URL=http://localhost:3000
# Password reset token expiration window in minutes
RESET_PASSWORD_TOKEN_TTL_MINUTES=30

# Uvicorn log level (critical, error, warning, info, debug, trace); invalid values are ignored
LOG_LEVEL=info
# Course thumbnail files are stored on disk (default: backend/uploads).
# UPLOADS_DIR=/app/uploads
