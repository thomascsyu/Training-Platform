# Database
MONGO_URL=mongodb://localhost:27017
# Zeabur's MongoDB service may provide MONGODB_URI instead; the app accepts either.
# MONGODB_URI=mongodb://localhost:27017
DB_NAME=learnhub

# Security (generate: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-me-to-a-random-secret

# Environment: development | production
ENVIRONMENT=development
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:3000

# Admin seed account (created on first startup if missing)
ADMIN_EMAIL=admin@learnhub.com
ADMIN_PASSWORD=change-me-in-production

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
REQUIRE_STRIPE_WEBHOOK_SECRET=false

# Deepseek AI (https://platform.deepseek.com)
DEEPSEEK_API_KEY=

# Brevo Email (https://app.brevo.com/settings/keys/api)
BREVO_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=LearnHub

# Frontend URL (for email links and CORS)
FRONTEND_URL=http://localhost:3000

# Uvicorn log level (critical, error, warning, info, debug, trace); invalid values are ignored
LOG_LEVEL=info
