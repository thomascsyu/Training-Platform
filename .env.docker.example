# Copy to .env in repo root for docker compose: cp .env.docker.example .env

JWT_SECRET=generate-with-python-secrets-token-hex-32
ADMIN_PASSWORD=change-me-in-production
ADMIN2_EMAIL=admin2@learnhub.com
ADMIN2_PASSWORD=change-me-admin2

# Browser-reachable API URL (optional — leave unset for same-origin /api proxy).
# REACT_APP_BACKEND_URL=http://localhost:8001
# Runtime proxy target for the frontend container (Docker / production).
# Docker Compose: http://api:8080
# Zeabur: http://training-platform.zeabur.internal:8080 (API → Networking → Private)
BACKEND_PROXY_URL=http://api:8080
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

ENVIRONMENT=development
COOKIE_SECURE=false

# Optional MongoDB authentication (recommended for production)
# When both are set, MONGO_URL is built automatically for the API service.
# MONGO_ROOT_USER=learnhub
# MONGO_ROOT_PASSWORD=change-me-in-production
# MONGO_URL=mongodb://learnhub:change-me-in-production@mongo:27017/?authSource=admin

# Optional integrations
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
REQUIRE_STRIPE_WEBHOOK_SECRET=false
DEEPSEEK_API_KEY=
BREVO_API_KEY=
EMAIL_FROM=noreply@learnhub.com
EMAIL_FROM_NAME=LearnHub

# Optional Uvicorn log level; invalid values fall back to info
LOG_LEVEL=info

# Persistent storage for uploaded course thumbnails (Docker Compose mounts this path).
UPLOADS_DIR=/app/uploads
