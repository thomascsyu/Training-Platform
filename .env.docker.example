# Copy to .env in repo root for docker compose: cp .env.docker.example .env

JWT_SECRET=generate-with-python-secrets-token-hex-32
ADMIN_PASSWORD=change-me-in-production

# Browser-reachable API URL (not the internal Docker service name)
REACT_APP_BACKEND_URL=http://localhost:8001
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

ENVIRONMENT=development
COOKIE_SECURE=false

# Optional integrations
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
REQUIRE_STRIPE_WEBHOOK_SECRET=false
DEEPSEEK_API_KEY=
BREVO_API_KEY=
EMAIL_FROM=noreply@learnhub.com
EMAIL_FROM_NAME=LearnHub
