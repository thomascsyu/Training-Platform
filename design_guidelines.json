{
  "theme": "light",
  "archetype": "4 (Swiss & High-Contrast)",
  "vibe": "Objective, authoritative, clear, function-first.",
  "typography": {
    "fonts": {
      "heading": "Clash Display",
      "body": "IBM Plex Sans",
      "mono": "JetBrains Mono"
    },
    "hierarchy": {
      "h1": "text-4xl sm:text-5xl lg:text-6xl tracking-tight font-medium",
      "h2": "text-2xl sm:text-3xl lg:text-4xl tracking-tight font-medium",
      "h3": "text-xl sm:text-2xl tracking-tight font-medium",
      "h4": "text-lg sm:text-xl font-medium",
      "body": "text-base leading-relaxed text-slate-800",
      "small": "text-sm text-slate-600",
      "overline": "text-xs tracking-[0.2em] uppercase font-bold text-slate-500"
    },
    "rules": [
      "Headings must use tight letter spacing (tracking-tight).",
      "Never use Inter for headings.",
      "Overlines must be uppercase, tiny, and widely spaced.",
      "Body text should be highly legible, strictly left-aligned."
    ]
  },
  "colors": {
    "primary": {
      "DEFAULT": "#002FA7",
      "hover": "#002585",
      "foreground": "#FFFFFF"
    },
    "background": {
      "app": "#F4F5F7",
      "card": "#FFFFFF",
      "glass": "rgba(255, 255, 255, 0.8)"
    },
    "text": {
      "primary": "#0A0B10",
      "secondary": "#475569",
      "muted": "#94A3B8",
      "inverse": "#FFFFFF"
    },
    "accent": {
      "success": "#10B981",
      "warning": "#F59E0B",
      "destructive": "#FF3B30",
      "destructive_foreground": "#FFFFFF"
    },
    "border": "#E2E8F0",
    "rules": [
      "Use pure #002FA7 (International Klein Blue) as the primary action color.",
      "Tinted greys must be used (Slate scale) instead of neutral greys.",
      "Strict high contrast. No low contrast text."
    ]
  },
  "spacing_and_layout": {
    "marketing": {
      "grid": "grid-cols-1 md:grid-cols-8 lg:grid-cols-12 gap-8 lg:gap-12",
      "container_padding": "px-6 md:px-12 lg:px-24",
      "section_spacing": "py-24 lg:py-32"
    },
    "dashboard": {
      "grid": "grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6",
      "container_padding": "p-6",
      "widget_padding": "p-6"
    },
    "radius": {
      "card": "rounded-none sm:rounded-sm",
      "button": "rounded-none sm:rounded-sm",
      "input": "rounded-none sm:rounded-sm"
    },
    "rules": [
      "Mode B: 'Control Room Grid' for the platform dashboard.",
      "Use sharp edges or minimal roundness (max 4px / rounded-sm).",
      "Expose the grid skeleton for technical views (border-collapse, 1px borders)."
    ]
  },
  "surfaces_and_components": {
    "header": {
      "style": "Glassmorphism with optical clarity",
      "classes": "backdrop-blur-xl bg-white/80 border-b border-slate-200"
    },
    "cards": {
      "style": "Technical/Grid Borders",
      "classes": "bg-white border border-slate-200 shadow-sm transition-all duration-200",
      "hover": "hover:-translate-y-1 hover:shadow-md hover:border-slate-300"
    },
    "buttons": {
      "primary": "bg-[#002FA7] text-white hover:bg-[#002585] shadow-sm",
      "secondary": "bg-white text-slate-800 border border-slate-200 hover:bg-slate-50",
      "ghost": "hover:bg-slate-100 text-slate-700 hover:text-slate-900"
    },
    "inputs": {
      "classes": "border-slate-300 bg-white focus:ring-2 focus:ring-[#002FA7]/20 focus:border-[#002FA7]"
    }
  },
  "motion_and_interactions": {
    "hover": "All interactive elements must have visible hover states.",
    "focus": "High contrast focus rings (focus:ring-2 focus:ring-[#002FA7]/20) on all inputs/buttons.",
    "transitions": "transition-all duration-200 ease-out",
    "testing": "All interactive and key informational elements MUST include a `data-testid` attribute (e.g., data-testid='course-enroll-button')."
  },
  "icons": {
    "library": "lucide-react",
    "style": "Clean, stroke-based, consistent sizing (w-5 h-5 for inline, w-8 h-8 for features)."
  },
  "media": {
    "rules": [
      "Use provided URLs exclusively. No placeholders.",
      "Overlay hero images with max bg-black/40 or bg-white/40."
    ],
