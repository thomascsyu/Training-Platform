# Browser-reachable API URL (optional).
# Leave unset to use same-origin /api (recommended). The dev server and
# production static server proxy /api to the backend using BACKEND_PROXY_URL.
# REACT_APP_BACKEND_URL=http://localhost:8001

# Container/dev-server proxy target for /api/* (not baked into the JS bundle).
# Local: http://localhost:8001
# Docker Compose: http://api:8080
# Zeabur: http://training-platform.zeabur.internal:8080
# BACKEND_PROXY_URL=http://localhost:8001
